rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: resumes
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The ID of the user who owns this resume
    //   - title: string (required, max 100 chars) - The title of the resume
    //   - createdAt: timestamp (required, immutable) - When the resume was created
    //   - updatedAt: timestamp (required) - When the resume was last updated
    //   - data: string (required, max 1MB) - JSON stringified ResumeData object
    //
    // Collection: published_resumes
    // Document ID: slug (e.g., 'johndoe-se')
    // Fields:
    //   - userId: string (required)
    //   - slug: string (required)
    //   - data: string (required, max 1MB)
    //   - publishedAt: timestamp (required)
    //   - views: number (required)
    //
    // Collection: published_resumes/{slug}/views
    // Document ID: auto-generated
    // Fields:
    //   - publishedResumeId: string (required)
    //   - viewedAt: timestamp (required)
    //   - location: string (optional, max 200 chars)
    //   - userAgent: string (optional, max 500 chars)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is owner based on document's userId field
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    // Verify userId hasn't been tampered with on create
    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }
    
    // Ensure userId field is not modified on update
    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }
    
    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Validate string length
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // Validate that the document hasn't changed in the fields that are not allowed to be changed
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidResume(data) {
      return hasOnlyAllowedFields(['userId', 'title', 'createdAt', 'updatedAt', 'data']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 128 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.data is string && data.data.size() > 0 && data.data.size() <= 1000000; // Max 1MB
    }

    function isValidPublishedResume(data) {
      return hasOnlyAllowedFields(['userId', 'slug', 'data', 'publishedAt', 'views']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 128 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 100 &&
             data.data is string && data.data.size() > 0 && data.data.size() <= 1000000 &&
             data.publishedAt is timestamp &&
             data.views is number && data.views >= 0;
    }

    function isValidResumeView(data) {
      return data.keys().hasAll(['publishedResumeId', 'viewedAt']) &&
             data.keys().hasOnly(['publishedResumeId', 'viewedAt', 'location', 'userAgent', 'timeSpent']) &&
             data.publishedResumeId is string && data.publishedResumeId.size() > 0 &&
             data.viewedAt is timestamp &&
             (!('location' in data) || (data.location is string && data.location.size() <= 200)) &&
             (!('userAgent' in data) || (data.userAgent is string && data.userAgent.size() <= 500)) &&
             (!('timeSpent' in data) || (data.timeSpent is number && data.timeSpent >= 0));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /resumes/{resumeId} {
      // Users can only read their own resumes
      allow read: if resource == null || isDocOwner();
      
      // Users can only create resumes for themselves
      allow create: if isAuthenticated() && 
                    isValidResume(request.resource.data) && 
                    uidUnchanged();
                    
      // Users can only update their own resumes, and cannot change the owner or creation date
      allow update: if isDocOwner() && 
                    isValidResume(request.resource.data) && 
                    uidNotModified() &&
                    areImmutableFieldsUnchanged(['createdAt']);
                    
      // Users can only delete their own resumes
      allow delete: if isDocOwner();
    }

    match /published_resumes/{slug} {
      // Anyone can read a published resume
      allow read: if true;
      
      // Users can publish their own resumes
      allow create: if isAuthenticated() && 
                    isValidPublishedResume(request.resource.data) && 
                    uidUnchanged() &&
                    request.resource.data.slug == slug;
                    
      // Users can update their published resumes, OR anyone can increment views
      allow update: if (isDocOwner() && 
                        isValidPublishedResume(request.resource.data) && 
                        uidNotModified() &&
                        areImmutableFieldsUnchanged(['publishedAt', 'slug', 'views'])) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
                        request.resource.data.views == resource.data.views + 1);
                        
      allow delete: if isDocOwner();
      
      match /views/{viewId} {
        // Only the owner of the published resume can read the views
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/published_resumes/$(slug)).data.userId == request.auth.uid;
        
        // Anyone can create a view event
        allow create: if isValidResumeView(request.resource.data) &&
                      request.resource.data.publishedResumeId == slug;
                      
        allow update: if isValidResumeView(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['timeSpent']);
                      
        allow delete: if false;
      }
    }
  }
}
